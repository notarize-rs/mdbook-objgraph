# SEV-SNP + TPM Attestation — Realistic Field Names
#
# This example uses actual field names from X.509/c509, TPM 2.0
# Structures, and AMD SEV-SNP Firmware ABI specifications.
#
# Design principles:
#   - Nodes represent TBS (To Be Signed) bodies for X.509 certificates;
#     signature verification is encoded by anchor links, not properties.
#   - Anchor operations carry the real algorithm name (ecdsa_p384, etc.).
#   - C509 registry identifiers (camelCase) for standard extensions
#     per draft-ietf-cose-cbor-encoded-cert-16 Figure 12.
#   - Project-defined sev.* identifiers for AMD SEV-SNP vendor extensions.
#   - Extensions with fixed/expected values (basicConstraints, keyUsage)
#     are @constrained — the verifier's policy engine validates them statically.
#   - Properties whose integrity is guaranteed by the anchor (signed TBS fields)
#     that also serve as constraint sources are @constrained.

domain "Verifier" {
  node System "System Clock" @anchored {
    current_time                     @constrained
  }

  node Challenge "Attestation Challenge" @anchored @selected {
    nonce                            @constrained
  }
}

domain "AMD SEV-SNP" {
  # Self-signed ECDSA P-384 root CA (AMD VCEK Certificate Spec §3)
  node ARK "AMD Root Key" @anchored {
    certificateSerialNumber
    issuer                           @critical
    validityNotBefore                @critical
    validityNotAfter                 @critical
    subject                          @constrained
    subjectPublicKey                 @constrained
    basicConstraints                 @constrained
    keyUsage                         @constrained
    subjectKeyIdentifier             @constrained
    authorityKeyIdentifier           @critical
  }

  # Intermediate CA signed by ARK
  node ASK "AMD Signing Key" {
    certificateSerialNumber
    issuer                           @critical
    validityNotBefore                @critical
    validityNotAfter                 @critical
    subject                          @constrained
    subjectPublicKey                 @constrained
    basicConstraints                 @constrained
    keyUsage                         @constrained
    subjectKeyIdentifier             @constrained
    authorityKeyIdentifier           @critical
  }

  # Leaf certificate with SEV-SNP custom OID extensions (1.3.6.1.4.1.3704.1.*)
  node VCEK "VCEK" {
    certificateSerialNumber
    issuer                           @critical
    validityNotBefore                @critical
    validityNotAfter                 @critical
    subject                          @constrained
    subjectPublicKey                 @constrained
    keyUsage                         @constrained
    authorityKeyIdentifier           @critical
    sev.hwId                         @constrained
    sev.tcb.bootloader               @constrained
    sev.tcb.tee                      @constrained
    sev.tcb.snp                      @constrained
    sev.tcb.microcode                @constrained
  }

  # AMD SEV-SNP Firmware ABI Specification Table 24
  node Report "Attestation Report" @selected {
    version
    guest_svn                        @critical
    policy.abi_major
    policy.abi_minor
    policy.smt
    policy.migration_agent
    policy.debug                     @constrained
    policy.single_socket             @constrained
    family_id
    image_id
    vmpl                             @constrained
    signature_algo
    platform_info.smt_enabled
    platform_info.tsme_enabled
    report_data                      @constrained
    measurement                      @critical
    host_data
    chip_id                          @critical
    tcb.committed.bootloader         @critical
    tcb.committed.tee                @critical
    tcb.committed.snp                @critical
    tcb.committed.microcode          @critical
    tcb.current.bootloader           @critical
    tcb.current.tee                  @critical
    tcb.current.snp                  @critical
    tcb.current.microcode            @critical
  }
}

domain "AMD KDS" {
  node KDS "Key Distribution Service" @anchored {
    tcb_versions                     @constrained
  }
}

domain "NIST" {
  node NVD @anchored {
    cve_entries                      @constrained
  }
}

domain "TPM" {
  # TPM manufacturer root CA
  node MfgCA "Manufacturer CA" @anchored {
    certificateSerialNumber
    issuer                           @critical
    validityNotBefore                @critical
    validityNotAfter                 @critical
    subject                          @constrained
    subjectPublicKey                 @constrained
    basicConstraints                 @constrained
    keyUsage                         @constrained
    subjectKeyIdentifier             @constrained
    authorityKeyIdentifier           @critical
  }

  # EK credential per TCG EK Credential Profile 2.0
  node EK "Endorsement Key" {
    certificateSerialNumber
    issuer                           @critical
    validityNotBefore                @critical
    validityNotAfter                 @critical
    subject
    subjectPublicKey                 @constrained
    subjectAltName                   @critical
    authorityKeyIdentifier           @critical
    certificatePolicies              @constrained
  }

  # TPM key object (not a certificate)
  node AK "Attestation Key" {
    public_area                      @critical
  }

  # TPMS_ATTEST structure (TPM 2.0 Part 2: Structures)
  node Quote "TPM Quote" {
    magic
    type
    qualified_signer                 @critical
    extra_data                       @critical
    clock_info
    firmware_version
    quote_info.pcr_select
    quote_info.pcr_digest            @constrained
  }

  # Sequence of TCG_PCR_EVENT2 entries
  node TCGLog "TCG Event Log" {
    pcr_index                        @constrained
    event_type                       @constrained
    digests                          @critical
    event_data
  }
}

domain "Guest vTPM" {
  # Custom structure binding vTPM identity to SEV-SNP report
  node GuestData "Guest Report Data" {
    nonce                            @critical
    ak_pub_hash                      @constrained
  }

  # vTPM endorsement key certificate
  node vEK "vTPM EK" {
    certificateSerialNumber
    issuer                           @constrained
    subject                          @constrained
    subjectPublicKey                 @constrained
    authorityKeyIdentifier           @critical
  }

  # vTPM attestation identity key
  node vAK "vTPM AK" {
    public_area                      @critical
  }

  # vTPM TPMS_ATTEST structure
  node vQuote "vTPM Quote" {
    magic
    extra_data
    qualified_signer                 @critical
    quote_info.pcr_select
    quote_info.pcr_digest            @constrained
  }

  # vTPM event log
  node vTCGLog "vTPM Event Log" {
    pcr_index                        @constrained
    event_type                       @constrained
    digests                          @critical
    event_data
  }
}

# ═══════════════════════════════════════════════════════════════
# Anchors (signature verification / trust derivation)
# ═══════════════════════════════════════════════════════════════

# AMD certificate chain
ASK <- ARK : ecdsa_p384
VCEK <- ASK : ecdsa_p384
Report <- VCEK : ecdsa_p384

# Physical TPM chain
EK <- MfgCA : rsa_2048
AK <- EK : tpm2_activate_credential
Quote <- AK : rsassa_pss
TCGLog <- Quote : pcr_replay

# SEV-SNP to vTPM binding
GuestData <- Report : sha256
vEK <- GuestData : ecdsa_p256
vAK <- vEK : tpm2_activate_credential
vQuote <- vAK : rsassa_pss
vTCGLog <- vQuote : pcr_replay

# ═══════════════════════════════════════════════════════════════
# AMD certificate chain constraints
# ═══════════════════════════════════════════════════════════════

# ARK self-signed checks
ARK::issuer <= ARK::subject : issuer_match
ARK::authorityKeyIdentifier <= ARK::subjectKeyIdentifier
ARK::validityNotBefore <= System::current_time : time_valid
ARK::validityNotAfter <= System::current_time : time_valid

# ASK issued by ARK
ASK::issuer <= ARK::subject : issuer_match
ASK::authorityKeyIdentifier <= ARK::subjectKeyIdentifier
ASK::validityNotBefore <= System::current_time : time_valid
ASK::validityNotAfter <= System::current_time : time_valid

# VCEK issued by ASK
VCEK::issuer <= ASK::subject : issuer_match
VCEK::authorityKeyIdentifier <= ASK::subjectKeyIdentifier
VCEK::validityNotBefore <= System::current_time : time_valid
VCEK::validityNotAfter <= System::current_time : time_valid

# ═══════════════════════════════════════════════════════════════
# Attestation Report constraints
# ═══════════════════════════════════════════════════════════════

Report::chip_id <= VCEK::sev.hwId

# TCB layered constraints:
#   VCEK sev.tcb <= committed_tcb <= current_tcb
# committed_tcb is the minimum the chip will boot; current_tcb is what's running.
# VCEK can express older values (until committed), so each layer must be >=.

# committed_tcb >= VCEK-certified TCB
Report::tcb.committed.bootloader <= VCEK::sev.tcb.bootloader : ge
Report::tcb.committed.tee <= VCEK::sev.tcb.tee : ge
Report::tcb.committed.snp <= VCEK::sev.tcb.snp : ge
Report::tcb.committed.microcode <= VCEK::sev.tcb.microcode : ge

# current_tcb >= committed_tcb
Report::tcb.current.bootloader <= Report::tcb.committed.bootloader : ge
Report::tcb.current.tee <= Report::tcb.committed.tee : ge
Report::tcb.current.snp <= Report::tcb.committed.snp : ge
Report::tcb.current.microcode <= Report::tcb.committed.microcode : ge

# committed_tcb components must be >= known-good versions (post-CVE)
# Report::tcb.committed.bootloader <= filter(KDS::tcb_versions, NVD::cve_entries) : ge
# Report::tcb.committed.tee <= filter(KDS::tcb_versions, NVD::cve_entries) : ge
# Report::tcb.committed.snp <= filter(KDS::tcb_versions, NVD::cve_entries) : ge
# Report::tcb.committed.microcode <= filter(KDS::tcb_versions, NVD::cve_entries) : ge
#
# Report::guest_svn <= filter(KDS::tcb_versions, NVD::cve_entries) : in

# ═══════════════════════════════════════════════════════════════
# TPM chain constraints
# ═══════════════════════════════════════════════════════════════

# MfgCA self-signed checks
MfgCA::issuer <= MfgCA::subject : issuer_match
MfgCA::authorityKeyIdentifier <= MfgCA::subjectKeyIdentifier
MfgCA::validityNotBefore <= System::current_time : time_valid
MfgCA::validityNotAfter <= System::current_time : time_valid

# EK issued by manufacturer
EK::issuer <= MfgCA::subject : issuer_match
EK::authorityKeyIdentifier <= MfgCA::subjectKeyIdentifier
EK::validityNotBefore <= System::current_time : time_valid
EK::validityNotAfter <= System::current_time : time_valid

# AK credential binding
AK::public_area <= EK::subjectPublicKey : tpm2_activate_credential

# Quote verification
Quote::qualified_signer <= AK::public_area : sha256_name
Quote::extra_data <= Challenge::nonce

# Event log replay
TCGLog::digests <= Quote::quote_info.pcr_digest : pcr_replay

# ═══════════════════════════════════════════════════════════════
# Guest vTPM constraints
# ═══════════════════════════════════════════════════════════════

# vEK authority bound through GuestData
vEK::authorityKeyIdentifier <= GuestData::ak_pub_hash

# vTPM key and quote chain
vAK::public_area <= vEK::subjectPublicKey : tpm2_activate_credential
vQuote::qualified_signer <= vAK::public_area : sha256_name
vTCGLog::digests <= vQuote::quote_info.pcr_digest : pcr_replay

# ═══════════════════════════════════════════════════════════════
# Cross-domain constraints
# ═══════════════════════════════════════════════════════════════

# Nonce freshness
GuestData::nonce <= Challenge::nonce
